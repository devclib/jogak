{
  "name": "@jogak/standalone-adapter",
  "version": "0.1.0-alpha.9.2",
  "description": "Standalone fallback adapter for Jogak — used when no builder is detected. Limited to user pre-built css.",
  "keywords": [
    "jogak",
    "standalone",
    "showcase"
  ],
  "author": {
    "name": "devclib",
    "url": "https://github.com/devclib"
  },
  "license": "MIT",
  "homepage": "https://github.com/devclib/jogak#readme",
  "bugs": "https://github.com/devclib/jogak/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devclib/jogak.git",
    "directory": "packages/standalone-adapter"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20.18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "peerDependencies": {
    "@jogak/core": "workspace:*",
    "vite": "^6.0.0 || ^7.0.0"
  },
  "devDependencies": {
    "@jogak/core": "workspace:*",
    "typescript": "^5.5.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch"
  }
}
