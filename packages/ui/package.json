{
  "name": "@jogak/ui",
  "version": "0.1.0-alpha.14.5",
  "description": "Showcase viewer UI for Jogak — Sidebar / Preview / Controls / Actions and the JogakApp shell.",
  "keywords": [
    "jogak",
    "storybook",
    "storybook-alternative",
    "showcase",
    "design-system",
    "component-library"
  ],
  "author": {
    "name": "devclib",
    "url": "https://github.com/devclib"
  },
  "license": "MIT",
  "homepage": "https://github.com/devclib/jogak#readme",
  "bugs": "https://github.com/devclib/jogak/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devclib/jogak.git",
    "directory": "packages/ui"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./host": {
      "types": "./dist/host/index.d.ts",
      "import": "./dist/host/index.mjs",
      "require": "./dist/host/index.cjs"
    }
  },
  "files": [
    "dist",
    "index.html",
    "preview-frame.html",
    "src/app",
    "src/components",
    "src/hooks",
    "src/lib/adapter-for.ts",
    "src/styles",
    "src/index.ts",
    "src/vite-env.d.ts",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20.18"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "vite build",
    "prepack": "vite build"
  },
  "dependencies": {
    "@jogak/core": "workspace:*",
    "@tailwindcss/vite": "^4.0.0",
    "clsx": "^2.1.1",
    "prism-react-renderer": "^2.4.1",
    "tailwindcss": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "happy-dom": "^20.9.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.5.0",
    "vite": "^6.4.3",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^2.0.0"
  },
  "peerDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "vite": "^6.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    },
    "@vitejs/plugin-react": {
      "optional": true
    }
  }
}