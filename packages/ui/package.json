{
  "name": "@jogak/ui",
  "version": "0.1.0-alpha.0",
  "description": "Showcase viewer UI for Jogak — Sidebar / Preview / Controls / Actions and the JogakApp shell.",
  "keywords": [
    "jogak",
    "storybook",
    "storybook-alternative",
    "showcase",
    "design-system",
    "component-library"
  ],
  "author": "devclib",
  "license": "MIT",
  "homepage": "https://github.com/devclib/jogak#readme",
  "bugs": "https://github.com/devclib/jogak/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devclib/jogak.git",
    "directory": "packages/ui"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./host": {
      "types": "./dist/host/index.d.ts",
      "import": "./dist/host/index.mjs",
      "require": "./dist/host/index.js"
    }
  },
  "files": [
    "dist",
    "index.html",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.10"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "vite build"
  },
  "dependencies": {
    "@jogak/core": "workspace:*",
    "@jogak/react": "workspace:*",
    "prism-react-renderer": "^2.4.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.5.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.5.4"
  },
  "peerDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "vite": "^6.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    },
    "@vitejs/plugin-react": {
      "optional": true
    }
  }
}
