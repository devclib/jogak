{
  "name": "@jogak/next",
  "version": "0.1.0-alpha.0",
  "description": "Next.js App Router embedding shell for Jogak.",
  "keywords": [
    "jogak",
    "storybook",
    "storybook-alternative",
    "showcase",
    "nextjs",
    "next-app-router",
    "design-system"
  ],
  "author": "devclib",
  "license": "MIT",
  "homepage": "https://github.com/devclib/jogak#readme",
  "bugs": "https://github.com/devclib/jogak/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devclib/jogak.git",
    "directory": "packages/next"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server/JogakLayout.d.ts",
      "import": "./dist/server/JogakLayout.js"
    },
    "./client": {
      "types": "./dist/client/Preview.d.ts",
      "import": "./dist/client/Preview.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.10"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@jogak/core": "workspace:*"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "happy-dom": "^20.9.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typescript": "^5.5.0",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "next": ">=14.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  }
}
