{
  "name": "@jogak/cli",
  "version": "0.1.0-alpha.6",
  "description": "jogak dev / build / generate — CLI for the Jogak component showcase.",
  "keywords": [
    "jogak",
    "storybook",
    "storybook-alternative",
    "showcase",
    "cli",
    "design-system",
    "component-library"
  ],
  "author": {
    "name": "devclib",
    "url": "https://github.com/devclib"
  },
  "license": "MIT",
  "homepage": "https://github.com/devclib/jogak#readme",
  "bugs": "https://github.com/devclib/jogak/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devclib/jogak.git",
    "directory": "packages/cli"
  },
  "type": "module",
  "bin": {
    "jogak": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20.18"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "tsc -p tsconfig.json",
    "prepack": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@jogak/core": "workspace:*",
    "@jogak/ui": "workspace:*",
    "vite": "^6.0.0",
    "@vitejs/plugin-react": "^4.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
