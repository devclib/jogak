{
  "name": "@jogak/react",
  "version": "0.1.0-alpha.5",
  "description": "React adapter for Jogak (useEntry / useRegistry / useRegistryMeta hooks + JogakProvider).",
  "keywords": [
    "jogak",
    "storybook",
    "storybook-alternative",
    "showcase",
    "react",
    "react-hooks",
    "design-system"
  ],
  "author": {
    "name": "devclib",
    "url": "https://github.com/devclib"
  },
  "license": "MIT",
  "homepage": "https://github.com/devclib/jogak#readme",
  "bugs": "https://github.com/devclib/jogak/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devclib/jogak.git",
    "directory": "packages/react"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20.18"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "vite build",
    "prepack": "vite build"
  },
  "dependencies": {
    "@jogak/core": "workspace:*"
  },
  "devDependencies": {
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0",
    "typescript": "^5.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  }
}
