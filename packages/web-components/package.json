{
  "name": "@jogak/web-components",
  "version": "0.1.0-alpha.0",
  "description": "Web Components adapter for Jogak — Preact runtime + Shadow DOM custom elements.",
  "keywords": [
    "jogak",
    "storybook",
    "storybook-alternative",
    "showcase",
    "web-components",
    "custom-elements",
    "shadow-dom",
    "preact"
  ],
  "author": "devclib",
  "license": "MIT",
  "homepage": "https://github.com/devclib/jogak#readme",
  "bugs": "https://github.com/devclib/jogak/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devclib/jogak.git",
    "directory": "packages/web-components"
  },
  "type": "module",
  "sideEffects": [
    "dist/iife.js"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "vite build"
  },
  "dependencies": {
    "@jogak/core": "workspace:*",
    "preact": "^10.23.0"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.8.0",
    "happy-dom": "^20.9.0",
    "typescript": "^5.5.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^2.1.9"
  }
}
