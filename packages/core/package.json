{
  "name": "@jogak/core",
  "version": "1.2.0",
  "description": "Core types, registry, and Vite plugin for Jogak — a lightweight Storybook alternative.",
  "keywords": [
    "jogak",
    "storybook",
    "storybook-alternative",
    "showcase",
    "design-system",
    "component-library",
    "vite-plugin"
  ],
  "author": {
    "name": "devclib",
    "url": "https://github.com/devclib"
  },
  "license": "MIT",
  "homepage": "https://github.com/devclib/jogak#readme",
  "bugs": "https://github.com/devclib/jogak/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devclib/jogak.git",
    "directory": "packages/core"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./vite-plugin": {
      "types": "./dist/vite-plugin/index.d.ts",
      "import": "./dist/vite-plugin/index.mjs",
      "require": "./dist/vite-plugin/index.cjs"
    },
    "./vite": {
      "types": "./dist/vite-plugin/index.d.ts",
      "import": "./dist/vite/index.mjs",
      "require": "./dist/vite/index.cjs"
    },
    "./build": {
      "types": "./dist/build/index.d.ts",
      "import": "./dist/build/index.mjs",
      "require": "./dist/build/index.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.mjs",
      "require": "./dist/server.cjs"
    },
    "./adapters/vite": {
      "types": "./dist/adapters/vite/index.d.ts",
      "import": "./dist/adapters/vite/index.mjs",
      "require": "./dist/adapters/vite/index.cjs"
    },
    "./adapters/next": {
      "types": "./dist/adapters/next/index.d.ts",
      "import": "./dist/adapters/next/index.mjs",
      "require": "./dist/adapters/next/index.cjs"
    },
    "./adapters/webpack": {
      "types": "./dist/adapters/webpack/index.d.ts",
      "import": "./dist/adapters/webpack/index.mjs",
      "require": "./dist/adapters/webpack/index.cjs"
    },
    "./adapters/standalone": {
      "types": "./dist/adapters/standalone/index.d.ts",
      "import": "./dist/adapters/standalone/index.mjs",
      "require": "./dist/adapters/standalone/index.cjs"
    },
    "./renderers/react": {
      "types": "./dist/renderers/react/index.d.ts",
      "import": "./dist/renderers/react/index.mjs",
      "require": "./dist/renderers/react/index.cjs"
    },
    "./renderers/next": {
      "types": "./dist/renderers/next/index.d.ts",
      "import": "./dist/renderers/next/index.mjs",
      "require": "./dist/renderers/next/index.cjs"
    },
    "./renderers/next/client": {
      "types": "./dist/renderers/next/client/index.d.ts",
      "import": "./dist/renderers/next/client/index.mjs",
      "require": "./dist/renderers/next/client/index.cjs"
    },
    "./renderers/next/server": {
      "types": "./dist/renderers/next/server/index.d.ts",
      "import": "./dist/renderers/next/server/index.mjs",
      "require": "./dist/renderers/next/server/index.cjs"
    },
    "./renderers/web-components": {
      "types": "./dist/renderers/web-components/index.d.ts",
      "import": "./dist/renderers/web-components/index.mjs",
      "require": "./dist/renderers/web-components/index.cjs"
    },
    "./renderers/vue": {
      "types": "./dist/renderers/vue/index.d.ts",
      "import": "./dist/renderers/vue/index.mjs",
      "require": "./dist/renderers/vue/index.cjs"
    },
    "./renderers/svelte": {
      "types": "./dist/renderers/svelte/index.d.ts",
      "import": "./dist/renderers/svelte/index.mjs",
      "require": "./dist/renderers/svelte/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20.18"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "vite build",
    "prepack": "vite build"
  },
  "dependencies": {
    "glob": "^11.0.0",
    "preact": "^10.23.0",
    "ts-morph": "^23.0.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^4.0.4",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "happy-dom": "^20.9.0",
    "html-webpack-plugin": "^5.0.0",
    "next": "^15.5.19",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "svelte": "^5.56.4",
    "typescript": "^5.5.0",
    "vite": "^6.4.3",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^3.2.6",
    "vue": "^3.4.0",
    "webpack": "^5.0.0",
    "webpack-dev-server": "^5.2.5",
    "webpack-merge": "^6.0.0"
  },
  "peerDependencies": {
    "axe-core": "^4.10.0",
    "html-webpack-plugin": "^5.0.0",
    "next": "^14.0.0 || ^15.0.0 || ^16.0.0",
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0",
    "svelte": "^5.0.0",
    "vite": "^6.0.0 || ^7.0.0",
    "vue": "^3.4.0",
    "webpack": "^5.0.0",
    "webpack-dev-server": "^5.0.0",
    "webpack-merge": "^6.0.0"
  },
  "peerDependenciesMeta": {
    "axe-core": {
      "optional": true
    },
    "vite": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "next": {
      "optional": true
    },
    "webpack": {
      "optional": true
    },
    "webpack-dev-server": {
      "optional": true
    },
    "webpack-merge": {
      "optional": true
    },
    "html-webpack-plugin": {
      "optional": true
    },
    "vue": {
      "optional": true
    },
    "svelte": {
      "optional": true
    }
  }
}
