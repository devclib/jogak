{
  "name": "@jogak/core",
  "version": "0.1.0-alpha.4",
  "description": "Core types, registry, and Vite plugin for Jogak — a lightweight Storybook alternative.",
  "keywords": [
    "jogak",
    "storybook",
    "storybook-alternative",
    "showcase",
    "design-system",
    "component-library",
    "vite-plugin"
  ],
  "author": {
    "name": "devclib",
    "url": "https://github.com/devclib"
  },
  "license": "MIT",
  "homepage": "https://github.com/devclib/jogak#readme",
  "bugs": "https://github.com/devclib/jogak/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devclib/jogak.git",
    "directory": "packages/core"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./vite": {
      "types": "./dist/vite/plugin.d.ts",
      "import": "./dist/vite/index.mjs"
    },
    "./build": {
      "types": "./dist/build/index.d.ts",
      "import": "./dist/build/index.mjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20.18"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "vite build",
    "prepack": "vite build"
  },
  "dependencies": {
    "glob": "^11.0.0",
    "ts-morph": "^23.0.0"
  },
  "devDependencies": {
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^2.0.0",
    "typescript": "^5.5.0",
    "@types/node": "^20.14.0"
  },
  "peerDependencies": {
    "vite": "^6.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  }
}
