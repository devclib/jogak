{
  "name": "jogak",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' build",
    "dev": "pnpm --filter @jogak/ui dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "typecheck": "tsc -b",
    "clean": "pnpm -r --filter './packages/*' exec rm -rf dist",
    "prebench": "pnpm --filter @jogak/core build",
    "bench": "node benchmarks/run.mjs",
    "prebench:extract": "pnpm --filter @jogak/core build",
    "bench:extract": "node benchmarks/extract-props.mjs",
    "bench:bundle": "node benchmarks/bundle-size.mjs",
    "bench:cold-start": "node benchmarks/cold-start.mjs",
    "bench:baseline": "JOGAK_BENCH_ONLY_BASELINE=1 JOGAK_BENCH_RUNS=1 node benchmarks/run.mjs",
    "bench:scale": "node benchmarks/run-scale.mjs",
    "bench:scale:full": "JOGAK_BENCH_SIZES=5,50,100,500 JOGAK_BENCH_INCLUDE_500=1 node benchmarks/run-scale.mjs"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "@preact/preset-vite"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/node": "^20.14.0",
    "@vitejs/plugin-react": "^4.3.0",
    "glob": "^11.1.0",
    "typescript": "^5.5.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^2.0.0"
  }
}
