{
  "name": "jogak",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' build",
    "dev": "pnpm --filter @jogak/ui dev",
    "lint": "pnpm lint:eslint && pnpm lint:traps",
    "lint:eslint": "eslint . --max-warnings=0",
    "lint:traps": "node scripts/lint-traps.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:functional": "playwright test --project=functional",
    "test:e2e:visual": "playwright test --project=visual",
    "test:e2e:visual:update": "playwright test --project=visual --update-snapshots",
    "test:e2e:visual:docker": "docker run --rm --ipc=host -e CI=true -v \"$PWD:/work\" -w /work mcr.microsoft.com/playwright:v1.59.1-jammy sh -lc \"corepack enable && corepack prepare pnpm@10 --activate && pnpm install --frozen-lockfile && pnpm --filter @jogak/core build && pnpm test:e2e:visual\"",
    "test:e2e:visual:docker:update": "docker run --rm --ipc=host -e CI=true -v \"$PWD:/work\" -w /work mcr.microsoft.com/playwright:v1.59.1-jammy sh -lc \"corepack enable && corepack prepare pnpm@10 --activate && pnpm install --frozen-lockfile && pnpm --filter @jogak/core build && pnpm test:e2e:visual:update\"",
    "pretest:e2e:framework": "pnpm --filter @jogak/core --filter @jogak/ui --filter @jogak/cli build",
    "test:e2e:framework:vue": "node e2e/framework-smoke.mjs --fixture=vue",
    "test:e2e:framework:svelte": "node e2e/framework-smoke.mjs --fixture=svelte",
    "test:e2e:framework": "pnpm test:e2e:framework:vue && pnpm test:e2e:framework:svelte",
    "typecheck": "tsc -b",
    "clean": "pnpm -r --filter './packages/*' exec rm -rf dist",
    "prebench": "pnpm --filter @jogak/core build",
    "bench": "node benchmarks/run.mjs",
    "prebench:extract": "pnpm --filter @jogak/core build",
    "bench:extract": "node benchmarks/extract-props.mjs",
    "bench:bundle": "node benchmarks/bundle-size.mjs",
    "bench:cold-start": "node benchmarks/cold-start.mjs",
    "bench:baseline": "JOGAK_BENCH_ONLY_BASELINE=1 JOGAK_BENCH_RUNS=1 node benchmarks/run.mjs",
    "bench:scale": "node benchmarks/run-scale.mjs",
    "bench:scale:full": "JOGAK_BENCH_SIZES=5,50,100,500 JOGAK_BENCH_INCLUDE_500=1 node benchmarks/run-scale.mjs",
    "bench:hmr": "node benchmarks/hmr-latency.mjs",
    "bench:rss": "node benchmarks/rss-idle.mjs"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "@preact/preset-vite"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/node": "^20.14.0",
    "@vitejs/plugin-react": "^4.3.0",
    "eslint": "^9.39.4",
    "glob": "^11.1.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.59.2",
    "vite": "^6.4.3",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^2.0.0"
  }
}
